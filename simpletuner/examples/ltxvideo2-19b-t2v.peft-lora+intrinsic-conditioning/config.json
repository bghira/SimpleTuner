{
    "base_model_precision": "int8-torchao",
    "musubi_blocks_to_swap": 45,
    "caption_dropout_probability": 0.1,
    "checkpoint_step_interval": 100,
    "checkpoints_total_limit": 5,
    "compress_disk_cache": true,
    "data_backend_config": "config/examples/multidatabackend-small-video-480p+2s24fps.json",
    "disable_benchmark": true,
    "gradient_checkpointing": true,
    "hub_model_id": "simpletuner-ltxvideo2-19b-t2v-intrinsic-lora-test",
    "learning_rate": 6e-5,
    "lora_rank": 16,
    "lora_type": "standard",
    "lr_scheduler": "constant_with_warmup",
    "lr_warmup_steps": 50,
    "ltx2_intrinsic_conditioning": [
        {
            "type": "first_frame",
            "probability": 0.5
        },
        {
            "type": "prefix",
            "probability": 0.25,
            "temporal_boundary": 2
        },
        {
            "type": "suffix",
            "probability": 0.25,
            "temporal_boundary": 1
        },
        {
            "type": "spatial_crop",
            "probability": 0.1,
            "spatial_region": [
                0,
                0,
                2,
                2
            ]
        }
    ],
    "max_grad_norm": 0.1,
    "max_train_steps": 200,
    "minimum_image_size": 0,
    "mixed_precision": "bf16",
    "model_family": "ltxvideo2",
    "model_type": "lora",
    "num_train_epochs": 0,
    "optimizer": "adamw_bf16",
    "output_dir": "output/examples/ltxvideo2-19b-t2v.peft-lora+intrinsic-conditioning",
    "report_to": "none",
    "resolution": 480,
    "resolution_type": "pixel_area",
    "resume_from_checkpoint": "latest",
    "seed": 42,
    "tracker_project_name": "lora-training",
    "tracker_run_name": "ltxvideo2-intrinsic-conditioning-example",
    "train_batch_size": 2,
    "vae_batch_size": 1,
    "vae_enable_tiling": true,
    "vae_enable_slicing": true,
    "validation_guidance": 5.0,
    "validation_negative_prompt": "blurry, cropped, ugly",
    "validation_num_inference_steps": 40,
    "validation_num_video_frames": 81,
    "validation_prompt": "🟫 is holding a sign that says hello world from ltxvideo2",
    "validation_prompt_library": false,
    "validation_resolution": "768x512",
    "validation_seed": 42,
    "validation_steps": 50
}
